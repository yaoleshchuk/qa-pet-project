# ── Application URLs ──────────────────────────────────────────────────────────
BASE_URL=https://www.booking.com
API_URL=https://www.booking.com

# ── Test credentials (use a dedicated test account, never production) ─────────
TEST_USER_EMAIL=your@email.com
TEST_USER_PASSWORD=yourpassword

# ── Default search parameters ─────────────────────────────────────────────────
DEFAULT_CITY=London
DEFAULT_CHECKIN=2026-06-01
DEFAULT_CHECKOUT=2026-06-05
DEFAULT_ADULTS=2

# ── Optional: pre-issued Bearer token for API tests ───────────────────────────
AUTH_TOKEN=
