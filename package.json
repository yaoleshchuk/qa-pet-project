{
  "name": "qa-pet-project",
  "version": "1.0.0",
  "description": "QA automation showcase: Cypress + Playwright + Gherkin BDD + GitHub Actions",
  "private": true,
  "scripts": {
    "test:pw:dry-run": "cucumber-js --profile default --dry-run",
    "test:pw:acceptance": "cucumber-js --profile acceptance",
    "test:pw:smoke": "cucumber-js --profile smoke",
    "test:pw:regression": "cucumber-js --profile regression",
    "test:cypress:open": "cypress open",
    "test:cypress:run": "cypress run",
    "test:cypress:acceptance": "cypress run --env tags=@Acceptance",
    "test:cypress:smoke": "cypress run --env tags=@Smoke",
    "test:cypress:regression": "cypress run --env tags=@Regression"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^20.1.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.1",
    "@cucumber/cucumber": "^10.8.0",
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.12.0",
    "cypress": "^13.10.0",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
